{
  "name": "@poozle/jira",
  "version": "0.1.0",
  "description": "Jira extension for Poozle",
  "exports": {
    ".": {
      "types": "./jira",
      "import": "./jira/index.js"
    }
  },
  "module": "./jira/index.jsx",
  "types": "./jira",
  "files": [
    "jira"
  ],
  "scripts": {
    "build": "rimraf jira && npm run build:js && npm run copy:spec",
    "build:js": "rollup -c",
    "build:types": "tsc --emitDeclarationOnly",
    "copy:spec": "cp spec.json jira/"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.18.2",
    "@babel/preset-env": "^7.18.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.17.12",
    "@rollup/plugin-babel": "5.3.1",
    "@rollup/plugin-commonjs": "^22.0.0",
    "@rollup/plugin-json": "^4.1.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@types/react": "^18.0.20",
    "@types/styled-components": "^5.1.26",
    "node-sass": "^7.0.3",
    "postcss": "^8.4.16",
    "prettier": "^2.6.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.74.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.34.0",
    "sass-loader": "^13.0.2",
    "typescript": "^4.7.2",
    "typescript-plugin-css-modules": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@poozle/edk": "^0.1.17",
    "react-select": "^5.4.0",
    "styled-components": "^5.0.1"
  }
}
