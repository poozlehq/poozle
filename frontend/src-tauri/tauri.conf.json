{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "yarn build",
    "beforeDevCommand": "yarn dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "poozle",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "notification": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [ "https://**" ]
      },
      "globalShortcut": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": [
          "$RESOURCE/extensions/*",
          "$RESOURCE/extensions/**",
          "$RESOURCE/extensions/**/*",
          "$RESOURCE/extensions",
          "$RESOURCE/**",
          "$APP/extensions/*",
          "$APP/extensions/**",
          "$APP/extensions/**/*",
          "$APP/extensions",
          "$APP/**",
          "$APP/icons/*"
        ]
      },
      "shell": {
        "all": true,
        "execute": true,
        "sidecar": true,
        "open": true,
        "scope": [ {
            "name": "run-sh",
            "cmd": "sh",
            "args": [ { "validator": "\\S+" } ]
          } ]
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "deb": {
        "depends": [ ]
      },
      "externalBin": [ ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.poozlehq.dev",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [ ],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [ ],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false,
      "endpoints": [
        "https://raw.githubusercontent.com/poozlehq/poozle/main/VERSION.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVGOURGQzk4NUU5NUU2NzgKUldSNDVwVmVtUHlkWDJ1QU9IMjMvVlAwWkYrZ2RXMklheTdESmVIaVZZNXFrSmFBZ05Wei9HUzIK"
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "url": "/main",
        "fullscreen": false,
        "transparent": true,
        "resizable": false,
        "width": 800,
        "height": 720,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "decorations": false
      }
    ]
  }
}